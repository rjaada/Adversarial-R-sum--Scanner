# ── Environment ──────────────────────────────────────────────────────────────
# "development" relaxes CORS to "*" for local work. Set to "production" on
# Render/Railway so the API refuses wildcard origins and uses ALLOWED_ORIGINS.
ENVIRONMENT=development

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=

# ── Clerk JWT verification ────────────────────────────────────────────────────
# Find in: Clerk Dashboard → API Keys → Advanced → JWT verification endpoint
# Format: https://<your-clerk-frontend-api>/.well-known/jwks.json
CLERK_JWKS_URL=

# ── Stripe (Phase 2) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Internal cron secret ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
INTERNAL_CRON_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Required when ENVIRONMENT != development.
# Production example:
#   ALLOWED_ORIGINS=https://tracerank.vercel.app
# Local dev (optional — defaults to "*" in development):
#   ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOWED_ORIGINS=

# ── LLM / AI rewrites (optional) ─────────────────────────────────────────────
LLM_ENDPOINT=
LLM_MODEL=llama3-8b-8192
LLM_API_KEY=
LLM_TIMEOUT=30

# ── Feature flags ─────────────────────────────────────────────────────────────
ATS_SIMULATION_ENABLED=false
ANALYTICS_ENABLED=false

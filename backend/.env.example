# ── Database (optional) ──────────────────────────────────────────────────────
# Leave blank to run without persistence. Scan history and compare-from-history
# will be unavailable, but scan/export/rewrite all work.
DATABASE_URL=

# ── LLM / AI rewrites (optional) ─────────────────────────────────────────────
# Leave blank to disable AI rewrite suggestions entirely (graceful no-op).
#
# Local Ollama:  LLM_ENDPOINT=http://localhost:11434   LLM_API_KEY=  (blank)
# Groq free:     LLM_ENDPOINT=https://api.groq.com/openai   LLM_API_KEY=gsk_...
#
# NOTE: LLM_ENDPOINT is the server root — /v1/chat/completions is appended automatically.
LLM_ENDPOINT=
LLM_MODEL=llama3-8b-8192
LLM_API_KEY=
LLM_TIMEOUT=30

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local default covers both Next.js dev ports; no change needed for local dev.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Feature flags ─────────────────────────────────────────────────────────────
ATS_SIMULATION_ENABLED=false
ANALYTICS_ENABLED=false

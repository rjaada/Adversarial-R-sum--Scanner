# Clerk — from Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk routing — in-app auth pages (without these, protected-route
# redirects go to Clerk's hosted portal instead of our custom pages)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Clerk post-auth redirects (v6 names; AFTER_SIGN_IN_URL is deprecated)
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/workspace
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/workspace

# Stripe (Phase 2 — fill in now for Phase 2 readiness)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=

# Backend URL (for local dev — production uses Next.js rewrites to Railway)
# BACKEND_URL=http://localhost:8000
